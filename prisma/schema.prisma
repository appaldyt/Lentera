// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(USER)
  status    String    @default("AKTIF")
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

model Training {
  id           String                @id @default(cuid())
  name         String
  description  String?
  jobFamilies  String[]
  classification String                @default("")
  trainingType String                @default("MANDATORY")
  organizer    String
  room         String
  startDate    DateTime
  endDate      DateTime?
  duration     String
  cost         String
  status       String                @default("PLANNING")
  preparations TrainingPreparation[]
  participants TrainingParticipant[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model TrainingPreparation {
  id           String   @id @default(cuid())
  trainingId   String
  training     Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  activityName String
  category     String
  dueDate      DateTime
  priority     String   @default("Normal")
  pic          String
  team         String
  isCompleted  Boolean  @default(false)
  progress     String   @default("0%")
  linkOutput   String?
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TrainingParticipant {
  id            String   @id @default(cuid())
  trainingId    String
  training      Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  nik           String
  name          String
  department    String
  trainingDate  DateTime
  attendedHours Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Employee {
  id             String   @id @default(cuid())
  nik            String   @unique
  name           String
  division       String
  position       String
  email          String   @unique
  phone          String
  workLocation   String
  lob            String
  bodLevel       String   @default("")
  employeeStatus String   @default("PKWTT")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Budget {
  id             String          @id @default(cuid())
  trainingName   String
  budgetYear     Int
  budgetMonth    Int
  trainingType   String          @default("Mandatori")
  plannedAmount  Int             @default(0)
  actualAmount   Int             @default(0)
  invoiceNumber  String          @default("")
  invoiceDate    DateTime?
  organizer      String          @default("")
  dueDate        DateTime?
  status         String          @default("Belum Dibayar")
  approvalStatus String          @default("Menunggu Persetujuan")
  processes      BudgetProcess[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model BudgetProcess {
  id         String    @id @default(cuid())
  budgetId   String
  budget     Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  stepNo     Int
  tahap      String
  status     String    @default("Belum")
  tanggal    DateTime?
  keterangan String    @default("")
  linkBukti  String    @default("")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Room {
  id          String         @id @default(cuid())
  name        String
  capacity    Int
  ownership   String
  ownerEntity String         @default("")
  location    String
  photoLink   String         @default("")
  facilities  RoomFacility[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model RoomFacility {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name      String
  type      String   @default("")
  quantity  Int      @default(1)
  photoLink String   @default("")
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vendor {
  id           String   @id @default(cuid())
  name         String
  location     String
  phone        String
  email        String
  topics       String[]
  method       String   @default("Online")
  status       String   @default("AKTIF")
  priceMin     Int      @default(0)
  priceMax     Int      @default(0)
  rating       Float    @default(0)
  usedBefore   Boolean  @default(false)
  notes        String   @default("")
  legalDocUrl  String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SelfLearning {
  id         String   @id @default(cuid())
  nik        String
  name       String
  department String   @default("")
  year       String   @default("")
  platform   String   @default("")
  hours      Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model License {
  id             String   @id @default(cuid())
  nik            String
  name           String
  position       String
  workLocation   String
  employeeStatus String
  lob            String
  licenseName    String
  licenseNumber  String   @default("-")
  category       String   @default("Operasional")
  issuedDate     DateTime
  expiryDate     DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([nik, licenseName])
}
